    "style-dictionary": "^5.5.0"
  },
  "dependencies": {
    "@lucide/svelte": "^1.25.0",
    "clsx": "^2.1.1",
    "svelte": "^5.56.7",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2"
  }
