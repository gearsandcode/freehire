{
  "$description": "Elevation/shadow scale. No shadow tokens existed before — shadows were inline Tailwind utilities.",
  "shadow-sm": {
    "$type": "shadow",
    "$value": { "x": 0, "y": 1, "blur": 2, "spread": 0, "color": "oklch(0 0 0 / 0.05)" },
    "$description": "Subtle elevation — dropdowns, tooltips."
  },
  "shadow-md": {
    "$type": "shadow",
    "$value": { "x": 0, "y": 2, "blur": 4, "spread": 0, "color": "oklch(0 0 0 / 0.1)" },
    "$description": "Default elevation — cards, popovers."
  },
  "shadow-lg": {
    "$type": "shadow",
    "$value": { "x": 0, "y": 4, "blur": 12, "spread": 0, "color": "oklch(0 0 0 / 0.15)" },
    "$description": "High elevation — dialogs, modals."
  },
  "shadow-xl": {
    "$type": "shadow",
    "$value": { "x": 0, "y": 8, "blur": 24, "spread": 0, "color": "oklch(0 0 0 / 0.2)" },
    "$description": "Maximum elevation — overlays, toasts."
  }
}
